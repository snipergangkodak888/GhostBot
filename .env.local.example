# Local development only — copy to .env.local
# Never commit .env.local. Never use production Supabase or bot tokens here.

APP_ENV=development

# Safety guard: if local SUPABASE_URL matches this ref, `pnpm env:check` fails.
# Set to your Railway/production Supabase project ref (from the Supabase dashboard URL).
PRODUCTION_SUPABASE_PROJECT_REF=your-prod-project-ref

# Dev Supabase project (create a second free Supabase project for local/testing)
SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key
SUPABASE_ANON_KEY=your-dev-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key
SUPABASE_POOLER_DATABASE_URL=postgresql://postgres.YOUR_DEV_PROJECT_REF:YOUR_DEV_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_POOLER_REGION=aws-0-us-east-1

# Dev Telegram bot (create via @BotFather — separate from production bot)
TELEGRAM_BOT_TOKEN=123456:dev-bot-token
NEXT_PUBLIC_BOT_USERNAME=your_dev_bot_username

# Local URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Optional: reserved ngrok hostname for a fixed URL (usually requires a paid plan).
# Leave blank to let `npm run dev:bot` obtain a temporary URL automatically.
NGROK_URL=

# Optional Bot Lab identity overrides. Bot Lab is local-only and does not call Telegram.
BOT_LAB_TELEGRAM_ID=990000001
BOT_LAB_CHAT_ID=990000001
BOT_LAB_CHAT_TYPE=private

# Local admin (created by pnpm db:init against dev Supabase)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-local-password
ADMIN_JWT_SECRET=local-dev-jwt-secret-min-32-chars

CRON_SECRET=local-dev-cron-secret-min-32-chars

# Local reminder testing: run `pnpm dev:cron` in a third terminal (pings /api/cron/ops)
# CRON_PING_INTERVAL_MS=15000
# CRON_PING_URL=http://localhost:3000
