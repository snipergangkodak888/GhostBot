# Supabase
# Use the same project ref in all Supabase values.
SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase database connection for schema setup.
# Recommended for Railway: Supabase Connect -> Session pooler -> URI.
# Username must look like postgres.PROJECT_REF and port should be 5432.
SUPABASE_POOLER_DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_POOLER_REGION=aws-0-us-east-1

# Admin bootstrap account created by pnpm db:init.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_JWT_SECRET=replace-with-a-long-random-secret

# Public app URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Telegram
TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
NEXT_PUBLIC_BOT_USERNAME=your_bot_username
TELEGRAM_INITDATA_MAX_AGE_SEC=86400

# Cron protection
CRON_SECRET=replace-with-a-long-random-secret

# Telegram analytics, optional
NEXT_PUBLIC_TG_ANALYTICS_TOKEN=
NEXT_PUBLIC_TG_ANALYTICS_APP_NAME=

# Optional admin-only endpoint protection
ADMIN_TOKEN=
START_MESSAGE_ADMIN_TOKEN=
